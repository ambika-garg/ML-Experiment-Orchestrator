# =============================================================================
# ML Experiment Orchestrator — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.

# Demo Mode
# Set to true to run deterministic local agent responses without GOOGLE_API_KEY.
DEMO_MODE=false

# Google Gemini API Key (required when DEMO_MODE=false)
GOOGLE_API_KEY=your-google-api-key-here

# LLM Model (default: gemini-2.5-flash)
LLM_MODEL=gemini-2.5-flash

# Database URL
# PostgreSQL (production): postgresql+asyncpg://user:password@localhost:5432/ml_orchestrator
# SQLite (local dev):      sqlite+aiosqlite:///./ml_orchestrator.db
DATABASE_URL=sqlite+aiosqlite:///./ml_orchestrator.db

# MLflow Tracking URI
MLFLOW_TRACKING_URI=http://localhost:5001

# Experiment Settings
MAX_ITERATIONS=3
CONVERGENCE_THRESHOLD=0.01

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000

# Data Directory
DATA_DIR=./data
